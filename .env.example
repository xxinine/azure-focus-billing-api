# ---- Raw export storage (where Cost Management exports land) ----
BLOB_ACCOUNT_URL=https://<your-storage-account>.blob.core.windows.net
BLOB_CONTAINER=report

# ---- Curated storage (normalized FOCUS 1.3 parquet) ----
# Leave CURATED_ACCOUNT_URL / CURATED_CONTAINER empty to reuse the raw account
# and container. Set them to separate the curated data into its own account or
# container (recommended for least-privilege / lifecycle isolation).
CURATED_ACCOUNT_URL=
CURATED_CONTAINER=
CURATED_PREFIX=curated/focus

# ---- Auth: Service Principal (app registration) ----
# Modes: service_principal | managed_identity
AZURE_STORAGE_AUTH_MODE=service_principal
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ---- Storage backend ----
# azure_blob (default, reads/writes az://) | local (for offline dev/testing)
STORAGE_BACKEND=azure_blob
# Used only when STORAGE_BACKEND=local
LOCAL_DATA_ROOT=./data

# ---- Per-subscription config (one entry per subscription) ----
# cloud is only an aggregation label used by the query API.
# Two ways to configure (the inline JSON, if non-empty, overrides the file):
#
# (A) Recommended: a JSON file. Same format as the inline JSON below, so ops can
#     copy the file's contents verbatim into FOCUS_SUBSCRIPTIONS_CONFIG_JSON when
#     overriding inside a container. (.yaml is also supported if you prefer comments.)
FOCUS_SUBSCRIPTIONS_CONFIG_FILE=config/subscriptions.json
#
# (B) Inline JSON (handy for containers; overrides the file when set).
# Each subscription points at its own export prefix. China is a separate Azure
# China (21Vianet) cloud => its own storage account/prefix / separate deployment.
FOCUS_SUBSCRIPTIONS_CONFIG_JSON=[]

# ---- API ----
DEFAULT_PAGE_SIZE=100
MAX_PAGE_SIZE=1000

# ---- Daily scheduler (in-process APScheduler; times are UTC) ----
# Enable for single-instance deployments. For multi-instance or external
# scheduling, keep false and run `python -m ingestion.refresh` via cron/systemd.
SCHEDULER_ENABLED=true
SCHEDULER_HOUR=2
SCHEDULER_MINUTE=30
